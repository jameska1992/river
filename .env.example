# Copy to .env and fill in the required values before running docker compose up.

# --- Required ---

# Absolute path to your media directory on the host
MEDIA_PATH=/srv/media

# Secret key for signing JWTs — use a long random string in production
JWT_SECRET=change-me-in-production

# Admin account created on first boot
ADMIN_PASSWORD=changeme

# TMDB API key — get one free at https://www.themoviedb.org/settings/api
TMDB_API_KEY=

# --- Optional (defaults shown) ---

POSTGRES_PASSWORD=river
RABBITMQ_USER=river
RABBITMQ_PASSWORD=river

ADMIN_USERNAME=admin
ADMIN_EMAIL=admin@river.local

# How often river-scan rescans the media directory, in seconds
SCAN_INTERVAL=3600s

# ffmpeg worker counts
VIDEO_TRANS_WORKERS=2
AUDIO_TRANS_WORKERS=2
META_WORKERS=2

# JWT token lifetimes
JWT_ACCESS_EXPIRY_MINUTES=15
JWT_REFRESH_EXPIRY_DAYS=7
